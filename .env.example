# Public app URL used for NOWPayments invoice callbacks + redirects.
# In production this is set to https://voice-agents-local.prin7r.com on the host.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOWPayments hosted invoice (mandatory for Wave 2 SaaS landings).
# Variable names mirror payments-prototypes/.env.example for cross-project consistency.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# Plisio backup (no-KYC stablecoin invoices). Enabled per route, currently advisory.
PLISIO_API_KEY=

# Reown / WalletConnect direct-wallet fallback. Public; safe to expose at build.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Merchant settlement wallets (documentation reference only).
# Live values live in /Users/keer/.nth-kir-keys.env or the deployed .env.
MERCHANT_USDT_TRC20_ADDRESS=
MERCHANT_USDT_ERC20_ADDRESS=
MERCHANT_USDC_ERC20_ADDRESS=
MERCHANT_USDC_POLYGON_ADDRESS=
MERCHANT_USDT_BSC_ADDRESS=

# Sales/desk inbox shown on the landing for non-card buyers.
SUPPORT_EMAIL=desk@prin7r.com
